# -*- mode: ruby -*-
# vi: set ft=ruby :

# Holberton Web Infrastructure Lab
# 4 VMs: 1 LB + 2 Web/App servers + 1 DB
# Networking: Private network 192.168.56.x

Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/focal64"

  # === LOAD BALANCER ===
  config.vm.define "lb" do |lb|
    lb.vm.hostname = "lb"
    lb.vm.network "private_network", ip: "192.168.56.10"
    lb.vm.provider "virtualbox" do |vb|
      vb.memory = "512"
      vb.cpus = 1
      vb.name = "holberton-lb"
    end
    lb.vm.provision "shell", path: "provision_lb.sh"
  end

  # === WEB SERVER 1 ===
  config.vm.define "web1" do |web1|
    web1.vm.hostname = "web1"
    web1.vm.network "private_network", ip: "192.168.56.11"
    web1.vm.provider "virtualbox" do |vb|
      vb.memory = "512"
      vb.cpus = 1
      vb.name = "holberton-web1"
    end
    web1.vm.provision "shell", path: "provision_web.sh"
  end

  # === WEB SERVER 2 ===
  config.vm.define "web2" do |web2|
    web2.vm.hostname = "web2"
    web2.vm.network "private_network", ip: "192.168.56.12"
    web2.vm.provider "virtualbox" do |vb|
      vb.memory = "512"
      vb.cpus = 1
      vb.name = "holberton-web2"
    end
    web2.vm.provision "shell", path: "provision_web.sh"
  end

  # === DATABASE ===
  config.vm.define "db" do |db|
    db.vm.hostname = "db"
    db.vm.network "private_network", ip: "192.168.56.13"
    db.vm.provider "virtualbox" do |vb|
      vb.memory = "512"
      vb.cpus = 1
      vb.name = "holberton-db"
    end
    db.vm.provision "shell", path: "provision_db.sh"
  end
end
